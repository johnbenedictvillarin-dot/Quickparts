{
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cp .env.example .env && composer install --no-dev --optimize-autoloader --ignore-platform-reqs"
  },
  "deploy": {
    "healthcheckPath": "/healthcheck.php",
    "healthcheckTimeout": 100
  },
  "start": {
    "web": "php -S 0.0.0.0:$PORT -t public router.php"
  }
}
