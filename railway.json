{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK",
        "buildCommand": "composer install --no-dev --optimize-autoloader --ignore-platform-reqs"
    },
    "deploy": {
        "startCommand": "php artisan migrate --force && php -S 0.0.0.0:$PORT -t public"
    }
}
